POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
TARGET_DB_NAME=tpch
METADATA_DB_NAME=optimizer

OPTIMIZER_ENABLED=true
OPTIMIZER_CAPTURE_ENABLED=true
OPTIMIZER_PROMOTION_ENABLED=true
OPTIMIZER_MIN_EXECUTION_COUNT=10
OPTIMIZER_PROFILE=smoke
OPTIMIZER_INVOCATION_INTERVAL_SECONDS=300
PROMOTION_MIN_IMPROVEMENT_PCT=2.0

ENABLE_RULES=true
ENABLE_LLM=false
# Required only when ENABLE_LLM=true.
DEFAULT_MODEL=
TEMPERATURE=0.7
MAX_CANDIDATES_PER_REQUEST=3

TPCH_SCALE_FACTOR=1
TPCH_QUERIES_PATH=/app/tpch/queries-parameterized
TPCH_PARAMETERS_PATH=/app/tpch/parameters-parameterized
TPCH_WORKLOAD_MANIFEST_FILE=/app/tpch/tpch-parameterized-rule-corpus.json
TPCH_RUN_HELD_OUT_EVALUATION=true
TPCH_VALIDATION_PARAMETER_SET_LIMIT=3
TPCH_CAPTURE_EXPLAIN_PLANS=true
TPCH_MIN_PROMOTION_PAIRS=30
TPCH_PROMOTION_MIN_IMPROVEMENT_PCT=2.0
